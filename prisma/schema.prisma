generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("CUSTOMER") // CUSTOMER, VENDOR, UMKM, ADMIN
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  
  // Relations
  vendorProfile VendorProfile?
  umkmProfile   UmkmProfile?
  reviews       Review[]
  orders        CustomerOrder[]
  messagesSent  Message[] @relation("Sender")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model VendorProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName String
  slug        String   @unique
  description String?
  address     String?
  city        String?
  province    String?
  phone       String?
  minPax      Int?
  maxPax      Int?
  priceMin    Int?
  priceMax    Int?
  isActive    Boolean  @default(true)
  isVerified  Boolean  @default(false)
  rating      Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  menus          VendorMenu[]
  orders         CustomerOrder[]
  purchaseOrders PurchaseOrder[]
}

model VendorMenu {
  id              String        @id @default(cuid())
  vendorProfileId String
  vendor          VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  category        String        // PRASMANAN, NASI_BOX, etc.
  items           String        // Stored as JSON string for SQLite simplicity
  pricePerPax     Int
  minOrderPax     Int
  image           String?
  isAvailable     Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  orderItems      CustomerOrderItem[]
}

model UmkmProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName String
  slug         String   @unique
  description  String?
  address      String?
  city         String?
  province     String?
  phone        String?
  isActive     Boolean  @default(true)
  isVerified   Boolean  @default(false)
  rating       Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  products       UmkmProduct[]
  purchaseOrders PurchaseOrder[]
}

model UmkmProduct {
  id            String      @id @default(cuid())
  umkmProfileId String
  umkm          UmkmProfile @relation(fields: [umkmProfileId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  category      String      // KUE_PASTRY, SNACK, etc.
  pricePerUnit  Int
  unit          String      // porsi, box, pcs
  minOrder      Int
  image         String?
  isAvailable   Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  poItems       PurchaseOrderItem[]
}

model CustomerOrder {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  customerId      String
  customer        User          @relation(fields: [customerId], references: [id])
  vendorProfileId String
  vendor          VendorProfile @relation(fields: [vendorProfileId], references: [id])
  eventType       String
  eventDate       DateTime
  guestCount      Int
  status          String        // PENDING, CONFIRMED, etc.
  totalAmount     Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  items          CustomerOrderItem[]
  purchaseOrders PurchaseOrder[]
  reviews        Review[]
}

model CustomerOrderItem {
  id              String        @id @default(cuid())
  customerOrderId String
  order           CustomerOrder @relation(fields: [customerOrderId], references: [id], onDelete: Cascade)
  vendorMenuId    String
  menu            VendorMenu    @relation(fields: [vendorMenuId], references: [id])
  quantity        Int
  price           Int
  subtotal        Int
}

model PurchaseOrder {
  id              String        @id @default(cuid())
  poNumber        String        @unique
  vendorProfileId String
  vendor          VendorProfile @relation(fields: [vendorProfileId], references: [id])
  umkmProfileId   String
  umkm            UmkmProfile   @relation(fields: [umkmProfileId], references: [id])
  customerOrderId String?
  customerOrder   CustomerOrder? @relation(fields: [customerOrderId], references: [id])
  status          String
  totalAmount     Int
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  items PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  umkmProductId   String
  product         UmkmProduct   @relation(fields: [umkmProductId], references: [id])
  quantity        Int
  price           Int
  subtotal        Int
}

model Review {
  id              String        @id @default(cuid())
  reviewerId      String
  reviewer        User          @relation(fields: [reviewerId], references: [id])
  customerOrderId String?
  customerOrder   CustomerOrder? @relation(fields: [customerOrderId], references: [id])
  rating          Int
  comment         String?
  createdAt       DateTime      @default(now())
}

model Message {
  id        String   @id @default(cuid())
  senderId  String
  sender    User     @relation("Sender", fields: [senderId], references: [id])
  content   String
  createdAt DateTime @default(now())
}
